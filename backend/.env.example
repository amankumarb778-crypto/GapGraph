# PostgreSQL Database Connection String
# Since we are using Docker Compose, the default URL is:
DATABASE_URL="postgresql://gapgraph:gapgraph_secret@localhost:5432/gapgraph?schema=public"

# OpenAI API Key for LangChain Agents (Diagnoser)
# You can get this from https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Fastify Server Port
PORT=3001
